@page
@model Website_Selling_Phones.Pages.Products.DetailsModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Product Details";
}

<div class="container py-5">
    @if (Model.Product != null)
    {
        <div class="row">
            <!-- Product Image -->
            <div class="col-md-6 mb-4">
                <img src="@Model.Product.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Product.Name" style="width: 100%; max-height: 500px; object-fit: cover;">
            </div>

            <!-- Product Info -->
            <div class="col-md-6">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item"><a href="/Products">Products</a></li>
                        <li class="breadcrumb-item active">@Model.Product.Name</li>
                    </ol>
                </nav>

                <h1 class="mb-2">@Model.Product.Name</h1>
                <p class="text-muted mb-3">@Model.Product.Brand</p>

                <h3 class="text-primary mb-4">$@Model.Product.Price.ToString("F2")</h3>

                <div class="mb-4">
                    <h5>Description</h5>
                    <p>@Model.Product.Description</p>
                </div>

                <div class="row mb-4">
                    <div class="col-6">
                        <strong>Model:</strong> @Model.Product.Model
                    </div>
                    <div class="col-6">
                        <strong>Stock:</strong> 
                        @if (Model.Product.StockQuantity > 0)
                        {
                            <span class="text-success">@Model.Product.StockQuantity available</span>
                        }
                        else
                        {
                            <span class="text-danger">Out of stock</span>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    @if (Model.Product.StockQuantity > 0)
                    {
                        <button class="btn btn-primary btn-lg" onclick="alert('Added to cart!')">
                            <i class="bi bi-cart-plus"></i> Add to Cart
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-lg" disabled>
                            Out of Stock
                        </button>
                    }
                    <a href="/Products" class="btn btn-outline-secondary btn-lg">Back to Products</a>
                </div>

                <div class="mt-4">
                    <small class="text-muted">
                        <i class="bi bi-truck"></i> Free shipping on orders over $500<br>
                        <i class="bi bi-shield-check"></i> 2-year warranty included<br>
                        <i class="bi bi-arrow-return-left"></i> 30-day return policy
                    </small>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h2>Product not found</h2>
            <a href="/Products" class="btn btn-primary mt-3">Back to Products</a>
        </div>
    }
</div>