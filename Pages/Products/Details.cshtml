@page
@model Website_Selling_Phones.Pages.Products.DetailsModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Product Details";
    Layout = "_ItemLayout";
}

@if (Model.Product != null)
{
    <div class="row g-5">
        <!-- Product Image -->
        <div class="col-lg-6">
            <div class="product-gallery">
                <img src="@Model.Product.ImageUrl" class="img-fluid w-100" alt="@Model.Product.Name" style="min-height: 400px; object-fit: cover;">
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-lg-6">
            <p class="text-muted text-uppercase small fw-bold mb-2">@Model.Product.Brand</p>
            <h1 class="fw-bold mb-3">@Model.Product.Name</h1>
            <p class="text-muted mb-4">@Model.Product.Description</p>

            <div class="price-tag mb-4">$@Model.Product.Price.ToString("F2")</div>

            <div class="row mb-4">
                <div class="col-6">
                    <small class="text-muted d-block">Model</small>
                    <strong>@Model.Product.Model</strong>
                </div>
                <div class="col-6">
                    <small class="text-muted d-block">Availability</small>
                    @if (Model.Product.StockQuantity > 0)
                    {
                        <span class="badge bg-success stock-badge">In Stock — @Model.Product.StockQuantity units</span>
                    }
                    else
                    {
                        <span class="badge bg-danger stock-badge">Out of Stock</span>
                    }
                </div>
            </div>

            <div class="d-flex gap-3 mb-4">
                @if (Model.Product.StockQuantity > 0)
                {
                    <button class="btn btn-primary btn-lg flex-grow-1" onclick="alert('Added to cart!')">
                        <i class="bi bi-cart-plus me-2"></i>Add to Cart
                    </button>
                    <button class="btn btn-outline-primary btn-lg px-3" title="Add to wishlist">
                        <i class="bi bi-heart"></i>
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg flex-grow-1" disabled>
                        <i class="bi bi-x-circle me-2"></i>Out of Stock
                    </button>
                }
            </div>

            <div class="border rounded p-3 bg-light">
                <div class="row text-center small">
                    <div class="col-4 border-end">
                        <i class="bi bi-truck text-primary d-block fs-4 mb-1"></i>
                        Free Shipping
                    </div>
                    <div class="col-4 border-end">
                        <i class="bi bi-shield-check text-primary d-block fs-4 mb-1"></i>
                        2-Year Warranty
                    </div>
                    <div class="col-4">
                        <i class="bi bi-arrow-return-left text-primary d-block fs-4 mb-1"></i>
                        30-Day Returns
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <i class="bi bi-emoji-frown"></i>
        <h4>Product Not Found</h4>
        <p>The product you're looking for doesn't exist or has been removed.</p>
        <a href="/Products" class="btn btn-primary mt-2">Browse Products</a>
    </div>
}