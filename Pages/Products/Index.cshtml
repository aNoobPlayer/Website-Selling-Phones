@page
@model Website_Selling_Phones.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Shop";
    Layout = "_ShopLayout";
}

<!-- Page Header -->
<section class="bg-light py-4 mb-4">
    <div class="container">
        <h2 class="fw-bold mb-1">All Phones</h2>
        <p class="text-muted mb-0">Browse our complete collection</p>
    </div>
</section>

<div class="container pb-5">
    <!-- Filters -->
    <div class="row mb-4">
        <div class="col-lg-6 mx-auto">
            <form method="get" class="d-flex gap-2">
                <div class="input-group shadow-sm rounded">
                    <span class="input-group-text bg-white border-end-0 rounded-start">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control border-start-0" placeholder="Search by name, brand, or keyword...">
                </div>
                <button type="submit" class="btn btn-primary px-4">Search</button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="/Products" class="btn btn-outline-secondary">Clear</a>
                }
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SearchTerm))
    {
        <div class="mb-3">
            <small class="text-muted">Results for "<strong>@Model.SearchTerm</strong>" — @Model.Products.Count phone(s) found</small>
        </div>
    }

    <!-- Product Grid -->
    <div class="row g-4">
        @foreach (var product in Model.Products)
        {
            <div class="col-md-4 col-lg-3 animate-in">
                <div class="card product-card h-100">
                    @if (product.StockQuantity > 0)
                    {
                        <span class="badge bg-success">In Stock</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Sold Out</span>
                    }
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 220px;">
                    <div class="card-body pb-2">
                        <p class="text-muted small mb-1">@product.Brand</p>
                        <h6 class="card-title fw-bold">@product.Name</h6>
                        <p class="fw-bold text-primary mb-0 fs-5">$@product.Price.ToString("F0")</p>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a href="/Products/Details?id=@product.Id" class="btn btn-outline-primary btn-sm w-50">View</a>
                        <button class="btn btn-primary btn-sm w-50" onclick="alert('Added to cart!')">Add to Cart</button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Products.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h4 class="text-muted">No phones found</h4>
            <p>Try adjusting your search or <a href="/Products">view all products</a></p>
        </div>
    }
</div>