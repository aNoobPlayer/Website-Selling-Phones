@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="hero-section text-center py-5 mb-5">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3">Welcome to PhoneStore</h1>
        <p class="lead mb-4">Discover the latest smartphones at unbeatable prices</p>
        <a href="/Products" class="btn btn-primary btn-lg">Shop Now</a>
    </div>
</div>

<!-- Featured Products -->
<div class="container mb-5">
    <h2 class="text-center mb-4">Featured Phones</h2>
    <div class="row">
        @foreach (var product in Model.FeaturedProducts)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 300px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-muted">@product.Brand</p>
                        <p class="card-text">@(product.Description?.Length > 100 ? product.Description.Substring(0, 100) + "..." : product.Description)</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 text-primary mb-0">$@product.Price.ToString("F2")</span>
                            <a href="/Products/Details?id=@product.Id" class="btn btn-outline-primary">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="text-center mt-4">
        <a href="/Products" class="btn btn-primary btn-lg">View All Products</a>
    </div>
</div>

<!-- Features Section -->
<div class="bg-light py-5 mb-5">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4 mb-3">
                <div class="feature-icon mb-3">
                    <i class="bi bi-truck fs-1 text-primary"></i>
                </div>
                <h4>Free Shipping</h4>
                <p class="text-muted">Free shipping on all orders over $500</p>
            </div>
            <div class="col-md-4 mb-3">
                <div class="feature-icon mb-3">
                    <i class="bi bi-shield-check fs-1 text-primary"></i>
                </div>
                <h4>2-Year Warranty</h4>
                <p class="text-muted">All phones come with warranty</p>
            </div>
            <div class="col-md-4 mb-3">
                <div class="feature-icon mb-3">
                    <i class="bi bi-arrow-return-left fs-1 text-primary"></i>
                </div>
                <h4>30-Day Returns</h4>
                <p class="text-muted">Easy returns within 30 days</p>
            </div>
        </div>
    </div>
</div>

<!-- Brands Section -->
<div class="container mb-5">
    <h2 class="text-center mb-4">Top Brands</h2>
    <div class="row text-center">
        <div class="col-6 col-md-3 mb-3">
            <div class="p-3 border rounded">
                <h5>Apple</h5>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="p-3 border rounded">
                <h5>Samsung</h5>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="p-3 border rounded">
                <h5>Google</h5>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="p-3 border rounded">
                <h5>OnePlus</h5>
            </div>
        </div>
    </div>
</div>