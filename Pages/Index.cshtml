@page
@model IndexModel
@{
    ViewData["Title"] = "PhoneStore - Your Next Phone Awaits";
    Layout = "_ShopLayout";
}

<!-- Parallax Hero -->
<section class="parallax-hero">
    <div class="parallax-layer parallax-layer-bg"></div>
    <div class="parallax-layer parallax-layer-mid"></div>
    <div class="parallax-layer parallax-layer-front">
        <div class="container">
            <div class="glass-hero-card text-center">
                <span class="hero-badge mb-3">New Collection 2026</span>
                <h1 class="hero-title">Your Next Phone<br>Awaits</h1>
                <p class="hero-subtitle">Discover the latest smartphones at unbeatable prices. Premium devices, refurbished gems, and budget champions — all in one place.</p>
                <div class="d-flex gap-3 justify-content-center mt-4">
                    <a href="/Product" class="btn-hero btn-hero-primary">Shop Now <i class="bi bi-arrow-right ms-2"></i></a>
                    <a href="/Product?condition=Refurbished" class="btn-hero btn-hero-outline">Refurbished Deals</a>
                </div>
                <div class="hero-stats mt-4">
                    <div class="hero-stat"><span class="hero-stat-value">10+</span><span class="hero-stat-label">Brands</span></div>
                    <div class="hero-stat"><span class="hero-stat-value">@Model.FeaturedPhones.Count</span><span class="hero-stat-label">Featured</span></div>
                    <div class="hero-stat"><span class="hero-stat-value">4.5★</span><span class="hero-stat-label">Avg Rating</span></div>
                    <div class="hero-stat"><span class="hero-stat-value">24/7</span><span class="hero-stat-label">Support</span></div>
                </div>
            </div>
        </div>
    </div>
    <div class="scroll-indicator">
        <span>Explore</span>
        <i class="bi bi-chevron-down"></i>
    </div>
</section>

<!-- Glass Feature Cards -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4" data-animate="fadeInUp">
                <div class="glass-feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="bi bi-truck"></i>
                    </div>
                    <h3>Free Shipping</h3>
                    <p>Free delivery on all orders over $500. Fast, reliable, and tracked every step of the way.</p>
                </div>
            </div>
            <div class="col-md-4" data-animate="fadeInUp">
                <div class="glass-feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h3>2-Year Warranty</h3>
                    <p>All phones come with full warranty coverage. Peace of mind with every purchase.</p>
                </div>
            </div>
            <div class="col-md-4" data-animate="fadeInUp">
                <div class="glass-feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="bi bi-arrow-return-left"></i>
                    </div>
                    <h3>30-Day Returns</h3>
                    <p>Not satisfied? Easy returns, no questions asked. Your satisfaction is guaranteed.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="py-5 bg-secondary-subtle">
    <div class="container">
        <div class="section-header mb-5">
            <div>
                <h2 class="section-title">Featured Phones</h2>
                <p class="section-subtitle">Hand-picked just for you</p>
            </div>
            <a href="/Product" class="btn btn-outline-primary">View All <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
        <div class="product-grid">
            @foreach (var phone in Model.FeaturedPhones)
            {
                <article class="product-card-v2" data-animate="fadeInUp">
                    <figure class="product-image-container">
                        <img src="@phone.ImageUrl" alt="@phone.Name" loading="lazy">
                        <figcaption class="condition-badge @phone.ConditionBadgeClass">@phone.ConditionDisplayName</figcaption>
                        @if (phone.DiscountPercentage > 0)
                        {<span class="discount-badge">-@phone.DiscountPercentage%</span>}
                        <div class="quick-actions">
                            <button class="btn btn-sm btn-light rounded-circle wishlist-toggle" data-id="@phone.Id" title="Wishlist"><i class="bi bi-heart"></i></button>
                            <button class="btn btn-sm btn-light rounded-circle quick-view-btn" data-id="@phone.Id" title="Quick View"><i class="bi bi-eye"></i></button>
                        </div>
                    </figure>
                    <div class="product-info">
                        <span class="brand-label">@phone.Brand</span>
                        <h3><a href="/Product/Details/@phone.Id">@phone.Name</a></h3>
                        <div class="mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {<i class="bi @(i <= Math.Round(phone.Rating) ? "bi-star-fill text-warning" : "bi-star text-muted") small"></i>}
                            <small class="text-muted ms-1">(@phone.ReviewCount)</small>
                        </div>
                        <div class="price-row">
                            @if (phone.DiscountPercentage > 0)
                            {<span class="original-price">$@phone.Price.ToString("F0")</span>}
                            <span class="current-price">$@phone.DiscountedPrice.ToString("F0")</span>
                        </div>
                        <small class="@phone.StockCssClass">@phone.StockStatus</small>
                    </div>
                    <footer class="product-actions">
                        <form class="ajax-cart-form" method="post" action="/Cart/AddAjax">
                            <input type="hidden" name="id" value="@phone.Id">
                            <input type="hidden" name="quantity" value="1">
                            <button type="submit" class="btn btn-primary btn-sm w-100 btn-add-to-cart">
                                <i class="bi bi-cart-plus me-1"></i>Add to Cart
                            </button>
                        </form>
                    </footer>
                </article>
            }
        </div>
    </div>
</section>

<!-- Trending Now -->
<section class="py-5">
    <div class="container">
        <div class="section-header mb-4">
            <div>
                <h2 class="section-title">Trending Now</h2>
                <p class="section-subtitle">What everyone's buying right now</p>
            </div>
        </div>
        <div class="trending-strip" data-animate="fadeInUp">
            @foreach (var phone in Model.PopularPhones)
            {
                <a href="/Product/Details/@phone.Id" class="trending-card">
                    <div class="trending-card-img">
                        <img src="@phone.ImageUrl" alt="@phone.Name" loading="lazy">
                        @if (phone.DiscountPercentage > 0)
                        {<span class="discount-badge">-@phone.DiscountPercentage%</span>}
                    </div>
                    <span class="trending-card-brand">@phone.Brand</span>
                    <strong class="trending-card-name">@phone.Name</strong>
                    <span class="trending-card-price">$@phone.DiscountedPrice.ToString("F0")</span>
                </a>
            }
        </div>
    </div>
</section>

<!-- Brand Cards -->
<section class="py-5 bg-secondary-subtle">
    <div class="container">
        <h2 class="section-title text-center mb-2">Shop by Brand</h2>
        <p class="section-subtitle text-center mb-5">Choose from the world's top manufacturers</p>
        <div class="row g-4">
            @foreach (var brand in Model.TopBrands)
            {
                <div class="col-6 col-md-3" data-animate="fadeInUp">
                    <a href="/Product?brand=@brand.Slug" class="glass-brand-card" data-tilt>
                        <div class="brand-card-icon"><i class="bi @brand.Icon"></i></div>
                        <span class="brand-card-name">@brand.Name</span>
                        <i class="bi bi-arrow-right brand-card-arrow"></i>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA Banner -->
<section class="py-5">
    <div class="container">
        <div class="cta-banner" data-animate="fadeInUp">
            <div>
                <h2 class="fw-bold mb-2">Ready to Upgrade?</h2>
                <p class="mb-0 opacity-75">Join over 10,000 happy customers. Free shipping on orders over $500.</p>
            </div>
            <a href="/Product" class="btn-hero btn-hero-primary">Browse All Phones <i class="bi bi-arrow-right ms-2"></i></a>
        </div>
    </div>
</section>

@section Scripts {
    <script type="module" src="~/js/modules/parallax-hero.js"></script>
    <script type="module" src="~/js/modules/tilt-cards.js"></script>
    <script>
        document.querySelectorAll('.quick-view-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                fetch('/Product/QuickView?id=' + this.dataset.id)
                    .then(r => r.text())
                    .then(html => {
                        var div = document.createElement('div');
                        div.innerHTML = html;
                        document.body.appendChild(div.firstElementChild);
                    });
            });
        });
    </script>
}