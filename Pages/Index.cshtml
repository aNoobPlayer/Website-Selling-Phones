@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
    Layout = "_ShopLayout";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container text-center text-white">
        <h1 class="mb-3">Your Next Phone<br>Awaits</h1>
        <p class="lead mb-4">Discover the latest smartphones at unbeatable prices</p>
        <a href="/Products" class="btn btn-lg">
            <i class="bi bi-arrow-right me-2"></i>Shop Now
        </a>
    </div>
</section>

<!-- Features -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-truck display-5 d-block mb-3"></i>
                    <h5>Free Shipping</h5>
                    <p class="text-muted small mb-0">Free delivery on all orders over $500</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-shield-check display-5 d-block mb-3"></i>
                    <h5>2-Year Warranty</h5>
                    <p class="text-muted small mb-0">All phones come with full warranty</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-arrow-return-left display-5 d-block mb-3"></i>
                    <h5>30-Day Returns</h5>
                    <p class="text-muted small mb-0">Easy returns, no questions asked</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1">Featured Phones</h2>
                <p class="text-muted mb-0">Hand-picked just for you</p>
            </div>
            <a href="/Products" class="btn btn-outline-primary">View All <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
        <div class="row g-4">
            @foreach (var product in Model.FeaturedProducts)
            {
                <div class="col-md-4 animate-in" style="animation-delay: @(Model.FeaturedProducts.IndexOf(product) * 0.1)s">
                    <div class="card product-card h-100">
                        <span class="badge bg-warning">Featured</span>
                        <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name">
                        <div class="card-body pb-2">
                            <p class="text-muted small mb-1">@product.Brand</p>
                            <h5 class="card-title fw-bold">@product.Name</h5>
                            <p class="card-text text-muted small">@(product.Description?.Length > 80 ? product.Description.Substring(0, 80) + "..." : product.Description)</p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <span class="h5 text-primary mb-0 fw-bold">$@product.Price.ToString("F0")</span>
                            <a href="/Products/Details?id=@product.Id" class="btn btn-outline-primary btn-sm">Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Brands -->
<section class="py-5">
    <div class="container">
        <h2 class="fw-bold mb-1 text-center">Shop by Brand</h2>
        <p class="text-muted text-center mb-4">Choose from the world's top manufacturers</p>
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <div class="brand-card text-center">🍎 Apple</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="brand-card text-center">📱 Samsung</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="brand-card text-center">📷 Google</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="brand-card text-center">⚡ OnePlus</div>
            </div>
        </div>
    </div>
</section>