@page
@model Website_Selling_Phones.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Admin Dashboard</h1>
        <a href="/Admin/Create" class="btn btn-success">
            <i class="bi bi-plus-lg"></i> Add New Product
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Products</h5>
                    <h2 class="mb-0">@Model.TotalProducts</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">In Stock</h5>
                    <h2 class="mb-0">@Model.InStockProducts</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">Featured</h5>
                    <h2 class="mb-0">@Model.FeaturedProducts</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Value</h5>
                    <h2 class="mb-0">$@Model.TotalValue.ToString("F0")</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Products Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">All Products</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Brand</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Featured</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td>
                                    <img src="@product.ImageUrl" alt="@product.Name" style="width: 50px; height: 50px; object-fit: cover;" class="rounded">
                                </td>
                                <td>@product.Name</td>
                                <td>@product.Brand</td>
                                <td>$@product.Price.ToString("F2")</td>
                                <td>
                                    @if (product.StockQuantity > 0)
                                    {
                                        <span class="badge bg-success">@product.StockQuantity</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">0</span>
                                    }
                                </td>
                                <td>
                                    @if (product.IsFeatured)
                                    {
                                        <span class="badge bg-warning">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No</span>
                                    }
                                </td>
                                <td>
                                    <a href="/Admin/Edit?id=@product.Id" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a href="/Products/Details?id=@product.Id" class="btn btn-sm btn-info" target="_blank">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@product.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this product?');">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>