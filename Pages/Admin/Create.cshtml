@page
@model Website_Selling_Phones.Pages.Admin.CreateModel
@{
    ViewData["Title"] = "Add Product";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a href="/Admin">Dashboard</a></li>
            <li class="breadcrumb-item active">Add Product</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i>New Product</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Product.Name" class="form-label fw-semibold">Product Name *</label>
                            <input asp-for="Product.Name" class="form-control" placeholder="e.g., iPhone 15 Pro Max" required>
                            <span asp-validation-for="Product.Name" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Product.Brand" class="form-label fw-semibold">Brand</label>
                                <input asp-for="Product.Brand" class="form-control" placeholder="e.g., Apple">
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Product.Model" class="form-label fw-semibold">Model</label>
                                <input asp-for="Product.Model" class="form-control" placeholder="e.g., A2890">
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Product.Price" class="form-label fw-semibold">Price ($) *</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="Product.Price" type="number" step="0.01" min="0" class="form-control" placeholder="999.99" required>
                                </div>
                                <span asp-validation-for="Product.Price" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Product.StockQuantity" class="form-label fw-semibold">Stock Quantity *</label>
                                <input asp-for="Product.StockQuantity" type="number" min="0" class="form-control" placeholder="10" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Product.ImageUrl" class="form-label fw-semibold">Image URL</label>
                            <input asp-for="Product.ImageUrl" class="form-control" placeholder="https://example.com/phone.jpg">
                        </div>

                        <div class="mb-3">
                            <label asp-for="Product.Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Product.Description" class="form-control" rows="4" placeholder="Describe the product..."></textarea>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="Product.IsFeatured" type="checkbox" class="form-check-input">
                            <label asp-for="Product.IsFeatured" class="form-check-label fw-semibold">Mark as Featured</label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-lg me-1"></i>Create Product
                            </button>
                            <a href="/Admin" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Tips</h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Use clear, descriptive product names</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Provide high-quality image URLs</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Set accurate stock quantities</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>Feature popular products for homepage</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}