<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="view-transition" content="same-origin" />
    <title>@ViewData["Title"] - PhoneStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        (function(){var t=localStorage.getItem('phonestore-theme');if(t==='dark'){document.documentElement.setAttribute('data-theme','dark');}})();
    </script>
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- Promo Bar -->
    <div class="promo-bar">
        <div class="container text-center">
            <span><i class="bi bi-truck me-1"></i>Free shipping on orders over $500</span>
            <span class="mx-3 d-none d-sm-inline">|</span>
            <span class="d-none d-sm-inline"><i class="bi bi-shield-check me-1"></i>30-day returns</span>
            <span class="mx-3 d-none d-sm-inline">|</span>
            <span class="d-none d-sm-inline"><i class="bi bi-stars me-1"></i>New arrivals every week</span>
            <button class="theme-toggle ms-3" onclick="toggleTheme()" title="Toggle dark mode" aria-label="Toggle dark mode"></button>
        </div>
    </div>

    <!-- Glassmorphism Navbar -->
    <nav class="navbar navbar-expand-lg shop-navbar sticky-top">
        <div class="container">
            @{ var currentPath = Context.Request.Path.Value ?? "/"; }
            <a class="navbar-brand fw-bold fs-4" href="/">
                <i class="bi bi-phone-fill me-2"></i>PhoneStore
            </a>
            <button class="navbar-toggler ms-auto me-2 cart-icon-mobile d-lg-none position-relative" style="background:none;border:none;color:var(--text-color);">
                <i class="bi bi-cart3 fs-5"></i>
                <span class="cart-count-badge position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
            </button>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#shopNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="shopNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-1">
                    <li class="nav-item"><a class="nav-link @(currentPath == "/" ? "active" : "")" href="/">Home</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(currentPath.StartsWith("/Product") ? "active" : "")" href="#" data-bs-toggle="dropdown">Shop</a>
                        <ul class="dropdown-menu shop-mega">
                            <li><a class="dropdown-item" href="/Product"><i class="bi bi-grid-fill me-2"></i>All Phones</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><h6 class="dropdown-header">By Brand</h6></li>
                            <li><a class="dropdown-item" href="/Product?brand=Apple">Apple</a></li>
                            <li><a class="dropdown-item" href="/Product?brand=Samsung">Samsung</a></li>
                            <li><a class="dropdown-item" href="/Product?brand=Google">Google</a></li>
                            <li><a class="dropdown-item" href="/Product?brand=OnePlus">OnePlus</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><h6 class="dropdown-header">By Condition</h6></li>
                            <li><a class="dropdown-item" href="/Product?condition=New"><span class="badge badge-new me-2">New</span>New</a></li>
                            <li><a class="dropdown-item" href="/Product?condition=Refurbished"><span class="badge badge-refurbished me-2">Ref</span>Refurbished</a></li>
                            <li><a class="dropdown-item" href="/Product?condition=Used"><span class="badge badge-used me-2">Used</span>Used</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/Product?sort=rating"><i class="bi bi-star-fill text-warning me-1 small"></i>Best Rated</a></li>
                    <li class="nav-item"><a class="nav-link text-accent fw-semibold" href="/Product?sort=popularity"><i class="bi bi-fire me-1"></i>Deals</a></li>
                </ul>
                <form class="search-form-desktop me-3" method="get" action="/Product">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input class="form-control" type="search" name="search" placeholder="Search phones, brands...">
                        <button class="btn btn-primary" type="submit">Search</button>
                    </div>
                </form>
                <div class="d-flex align-items-center gap-2">
                    <a href="/Cart" class="cart-btn-desktop position-relative" title="Cart">
                        <i class="bi bi-cart3 fs-5"></i>
                        <span class="cart-count-badge position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                    </a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <a href="#" class="user-btn" data-bs-toggle="dropdown" title="@User.Identity.Name">
                                <i class="bi bi-person-circle fs-5"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><h6 class="dropdown-header">@User.Identity.Name</h6></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item" href="/Admin"><i class="bi bi-speedometer2 me-2"></i>Admin Panel</a></li>
                                    <li><a class="dropdown-item" href="/Account/ManageUsers"><i class="bi bi-people me-2"></i>Manage Users</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li><a class="dropdown-item" href="/Order/History"><i class="bi bi-box me-2"></i>My Orders</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" action="/Account/Logout">
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Sign Out</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-outline-primary btn-sm">Sign In</a>
                        <a href="/Account/Register" class="btn btn-primary btn-sm">Register</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-shrink-0">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 pb-3 mt-auto mobile-pb">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold"><i class="bi bi-phone-fill text-primary me-2"></i>PhoneStore</h5>
                    <p class="text-muted small">Your trusted source for the latest smartphones at the best prices.</p>
                </div>
                <div class="col-md-2 mb-4">
                    <h6 class="fw-bold">Shop</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/Product" class="text-muted text-decoration-none">All Phones</a></li>
                        <li><a href="/Product?condition=New" class="text-muted text-decoration-none">New</a></li>
                        <li><a href="/Product?condition=Refurbished" class="text-muted text-decoration-none">Refurbished</a></li>
                        <li><a href="/Product?condition=Used" class="text-muted text-decoration-none">Used</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-4">
                    <h6 class="fw-bold">Support</h6>
                    <ul class="list-unstyled small">
                        <li><a href="#" class="text-muted text-decoration-none">Contact Us</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">FAQ</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Shipping Info</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Returns</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="fw-bold">Newsletter</h6>
                    <p class="text-muted small">Subscribe for exclusive deals and new arrivals.</p>
                    <form class="input-group newsletter-form" onsubmit="newsletterSubscribe(event)">
                        <input type="email" class="form-control form-control-sm" placeholder="Your email" required>
                        <button class="btn btn-primary btn-sm">Subscribe</button>
                    </form>
                </div>
            </div>
            <hr class="border-secondary">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <small class="text-muted">&copy; 2026 PhoneStore. All rights reserved.</small>
                <div class="d-flex gap-3 align-items-center">
                    <span class="text-muted small">Payment:</span>
                    <i class="bi bi-credit-card text-white-50"></i>
                    <span class="text-muted small">Visa</span>
                    <span class="text-muted small">Mastercard</span>
                    <i class="bi bi-paypal text-white-50"></i>
                </div>
                <small>
                    <a href="/Admin" class="text-muted text-decoration-none me-3">Admin</a>
                    <a href="/Privacy" class="text-muted text-decoration-none">Privacy</a>
                </small>
            </div>
        </div>
    </footer>

    <!-- Mobile Bottom Navigation -->
    <nav class="mobile-bottom-nav d-lg-none">
        <a href="/" class="mobile-nav-item @(currentPath == "/" ? "active" : "")">
            <i class="bi bi-house-fill"></i><span>Home</span>
        </a>
        <a href="/Product" class="mobile-nav-item @(currentPath == "/Product" ? "active" : "")">
            <i class="bi bi-grid-fill"></i><span>Shop</span>
        </a>
        <a href="/Cart" class="mobile-nav-item cart-nav-item @(currentPath == "/Cart" ? "active" : "")">
            <i class="bi bi-cart3"></i><span>Cart</span>
            <span class="cart-count-badge d-none">0</span>
        </a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a href="/Account/Manage" class="mobile-nav-item @(currentPath.StartsWith("/Account") ? "active" : "")">
                <i class="bi bi-person-check-fill"></i><span>Account</span>
            </a>
        }
        else
        {
            <a href="/Account/Login" class="mobile-nav-item">
                <i class="bi bi-person-fill"></i><span>Sign In</span>
            </a>
        }
    </nav>

    <!-- Back to Top -->
    <button id="backToTop" class="back-to-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Back to top">
        <i class="bi bi-chevron-up"></i>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        fetch('/Cart/GetCount').then(r => r.json()).then(d => {
            if (d.count > 0) {
                document.querySelectorAll('.cart-count-badge').forEach(b => { b.textContent = d.count; b.classList.remove('d-none'); });
            }
        });
        function newsletterSubscribe(e) {
            e.preventDefault();
            var input = e.target.querySelector('input');
            var btn = e.target.querySelector('button');
            var orig = btn.textContent;
            btn.textContent = 'Done!';
            btn.classList.add('btn-success');
            btn.classList.remove('btn-primary');
            input.value = '';
            setTimeout(() => { btn.textContent = orig; btn.classList.remove('btn-success'); btn.classList.add('btn-primary'); }, 2000);
        }
        window.addEventListener('scroll', () => {
            document.getElementById('backToTop')?.classList.toggle('visible', window.scrollY > 400);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>