<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PhoneStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- Top Bar -->
    <div class="top-bar bg-dark text-white py-1">
        <div class="container d-flex justify-content-between">
            <small><i class="bi bi-telephone-fill me-1"></i> +1 (555) 123-4567</small>
            <div class="d-flex align-items-center gap-3">
                <small><i class="bi bi-envelope-fill me-1"></i> support@phonestore.com</small>
                <!-- Dark Mode Toggle -->
                <button class="theme-toggle" onclick="toggleTheme()" title="Toggle dark mode" aria-label="Toggle dark mode"></button>
            </div>
        </div>
    </div>

    <!-- Glassmorphism Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark glass-nav sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" href="/">
                <i class="bi bi-phone-fill text-primary me-2"></i>PhoneStore
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#shopNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="shopNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Product">Shop</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Product?condition=New">New</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Product?condition=Refurbished">Refurbished</a></li>
                </ul>
                <form class="d-flex me-3" method="get" action="/Product">
                    <div class="input-group">
                        <input class="form-control form-control-sm" type="search" name="brand" placeholder="Search phones...">
                        <button class="btn btn-outline-light btn-sm" type="submit"><i class="bi bi-search"></i></button>
                    </div>
                </form>
                <a href="#" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-cart3"></i> Cart
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-shrink-0">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 pb-3 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold"><i class="bi bi-phone-fill text-primary me-2"></i>PhoneStore</h5>
                    <p class="text-muted small">Your trusted source for the latest smartphones at the best prices.</p>
                </div>
                <div class="col-md-2 mb-4">
                    <h6 class="fw-bold">Shop</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/Product" class="text-muted text-decoration-none">All Phones</a></li>
                        <li><a href="/Product?condition=New" class="text-muted text-decoration-none">New</a></li>
                        <li><a href="/Product?condition=Refurbished" class="text-muted text-decoration-none">Refurbished</a></li>
                        <li><a href="/Product?condition=Used" class="text-muted text-decoration-none">Used</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-4">
                    <h6 class="fw-bold">Support</h6>
                    <ul class="list-unstyled small">
                        <li><a href="#" class="text-muted text-decoration-none">Contact Us</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">FAQ</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Shipping Info</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Returns</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="fw-bold">Newsletter</h6>
                    <p class="text-muted small">Subscribe for exclusive deals and new arrivals.</p>
                    <div class="input-group">
                        <input type="email" class="form-control form-control-sm" placeholder="Your email">
                        <button class="btn btn-primary btn-sm">Subscribe</button>
                    </div>
                </div>
            </div>
            <hr class="border-secondary">
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">&copy; 2026 PhoneStore. All rights reserved.</small>
                <small>
                    <a href="/Admin" class="text-muted text-decoration-none me-3">Admin</a>
                    <a href="/Privacy" class="text-muted text-decoration-none">Privacy</a>
                </small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>