<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | PhoneStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    <!-- Admin Top Bar -->
    <nav class="navbar navbar-dark bg-dark px-3 shadow-sm">
        <a class="navbar-brand fw-bold fs-5" href="/Admin">
            <i class="bi bi-speedometer2 me-2"></i>PhoneStore Admin
        </a>
        <div class="d-flex align-items-center gap-3">
            <a href="/" class="text-white-50 text-decoration-none small" target="_blank">
                <i class="bi bi-box-arrow-up-right me-1"></i>View Store
            </a>
            <span class="text-white-50 small">
                <i class="bi bi-person-circle me-1"></i>Admin
            </span>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row flex-nowrap">
            <!-- Sidebar -->
            <div class="col-auto col-md-2 col-xl-2 px-0 bg-white border-end shadow-sm sidebar">
                <div class="d-flex flex-column min-vh-100 pt-3">
                    <ul class="nav flex-column px-2">
                        <li class="nav-item mb-1">
                            <a class="nav-link rounded @(Context.Request.Path == "/Admin" ? "active" : "")" href="/Admin">
                                <i class="bi bi-grid-fill me-2"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link rounded @(Context.Request.Path == "/Admin/Create" ? "active" : "")" href="/Admin/Create">
                                <i class="bi bi-plus-circle-fill me-2"></i>Add Product
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link rounded" href="/Products" target="_blank">
                                <i class="bi bi-shop me-2"></i>View Shop
                            </a>
                        </li>
                    </ul>
                    <hr class="mx-2 my-3">
                    <div class="px-2">
                        <small class="text-muted text-uppercase fw-bold px-2">Quick Stats</small>
                        <div class="mt-2 px-2">
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-muted">Products</span>
                                <span class="fw-bold">@ViewBag.TotalProducts</span>
                            </div>
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-muted">Featured</span>
                                <span class="fw-bold">@ViewBag.FeaturedProducts</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col py-3">
                <main>
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>