@model Website_Selling_Phones.Models.ShoppingCart
@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "_ShopLayout";
    var coupon = ViewData["Coupon"] as Website_Selling_Phones.Models.Coupon;
    var couponDiscount = (decimal)(ViewData["CouponDiscount"] ?? 0m);
    var shipping = (decimal)(ViewData["Shipping"] ?? 0m);
    var tax = (decimal)(ViewData["Tax"] ?? 0m);
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/Product">Shop</a></li>
            <li class="breadcrumb-item active">Cart</li>
        </ol>
    </nav>

    <h2 class="fw-bold mb-4">Shopping Cart <span class="text-muted fs-5">(@Model.TotalItems items)</span></h2>

    @if (Model.Items.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="border rounded">
                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-item d-flex align-items-center p-3 border-bottom">
                            <img src="@item.Phone?.ImageUrl" alt="@item.Phone?.Name" class="rounded me-3" style="width:80px; height:80px; object-fit:cover;">
                            <div class="flex-grow-1">
                                <h6 class="mb-1">@item.Phone?.Name</h6>
                                <small class="text-muted">@item.Phone?.Brand</small>
                                <div class="mt-1">
                                    <span class="fw-bold text-primary">$@item.Phone?.DiscountedPrice.ToString("F2")</span>
                                    @if (item.Phone?.DiscountPercentage > 0)
                                    {<small class="text-decoration-line-through text-muted ms-1">$@item.Phone?.Price.ToString("F2")</small>}
                                </div>
                            </div>
                            <div class="quantity-selector me-3" style="width:110px;">
                                <div class="input-group input-group-sm">
                                    <form method="post" action="/Cart/Update" class="d-flex">
                                        <input type="hidden" name="id" value="@item.PhoneId">
                                        <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control text-center" style="width:50px;" onchange="this.form.submit()">
                                    </form>
                                </div>
                            </div>
                            <div class="fw-bold me-4" style="min-width:70px;">$@((item.Phone?.DiscountedPrice * item.Quantity) ?? 0).ToString("F2")</div>
                            <form method="post" action="/Cart/Remove">
                                <input type="hidden" name="id" value="@item.PhoneId">
                                <button type="submit" class="btn btn-outline-danger btn-sm">&times;</button>
                            </form>
                        </div>
                    }
                </div>
                <a href="/Product" class="btn btn-outline-primary mt-3">
                    <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                </a>
            </div>

            <div class="col-lg-4">
                <!-- Coupon -->
                <div class="coupon-card mb-3">
                    <h6 class="fw-bold mb-2">Coupon Code</h6>
                    @if (coupon != null)
                    {
                        <div class="alert alert-success coupon-applied-alert py-2 px-3 mb-2 d-flex justify-content-between align-items-center">
                            <span><strong>@coupon.Code</strong> (@coupon.DiscountPercent% off)</span>
                            <form method="post" action="/Cart/RemoveCoupon">
                                <button type="submit" class="btn-close"></button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <form method="post" action="/Cart/ApplyCoupon" class="d-flex gap-1">
                            <input type="text" name="code" class="form-control form-control-sm" placeholder="Enter code">
                            <button type="submit" class="btn btn-sm btn-primary">Apply</button>
                        </form>
                        <small class="text-muted">Try: SAVE10, PHONE20, WELCOME5</small>
                    }
                </div>

                <!-- Order Summary -->
                <div class="order-summary-card mb-3">
                    <h6 class="fw-bold mb-3">Order Summary</h6>
                    <div class="d-flex justify-content-between mb-1"><span>Subtotal</span><span>$@Model.TotalPrice.ToString("F2")</span></div>
                    @if (couponDiscount > 0)
                    {<div class="d-flex justify-content-between mb-1 text-success"><span>Discount (@coupon?.Code)</span><span>-$@couponDiscount.ToString("F2")</span></div>}
                    <div class="d-flex justify-content-between mb-1"><span>Shipping</span><span>@(shipping == 0 ? "FREE" : $"${shipping:F2}")</span></div>
                    <div class="d-flex justify-content-between mb-2"><span>Tax (8%)</span><span>$@tax.ToString("F2")</span></div>
                    <hr>
                    @{
                        var total = Model.TotalPrice - couponDiscount + shipping + tax;
                    }
                    <div class="d-flex justify-content-between fw-bold mb-3"><span>Total</span><span class="fs-5">$@total.ToString("F2")</span></div>
                    <a href="/Order/Checkout" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-lock-fill me-1"></i>Proceed to Checkout
                    </a>
                </div>

                <!-- Trust Badges -->
                <div class="border rounded p-3 mt-3 small text-muted">
                    <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-lock-fill text-success"></i>Secure SSL Checkout</div>
                    <div class="d-flex align-items-center gap-2 mb-2"><i class="bi bi-shield-check text-success"></i>30-Day Money-Back</div>
                    <div class="d-flex align-items-center gap-2"><i class="bi bi-truck text-success"></i>Fast & Free Shipping</div>
                    <div class="d-flex gap-2 mt-3">
                        <span class="payment-pill">Visa</span>
                        <span class="payment-pill">Mastercard</span>
                        <span class="payment-pill">PayPal</span>
                        <span class="payment-pill">Apple Pay</span>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <h3 class="mt-3">Your cart is empty</h3>
            <p class="text-muted">Looks like you haven't added anything yet.</p>
            <a href="/Product" class="btn btn-primary btn-lg">Start Shopping</a>
        </div>
    }
</div>

@if (TempData["CouponError"] != null)
{
    <div class="toast-notification toast-error position-fixed top-0 end-0 m-3" id="couponToast">
        <i class="bi bi-x-circle me-1"></i>@TempData["CouponError"]
    </div>
    <script>setTimeout(()=>document.getElementById('couponToast')?.remove(), 4000);</script>
}
@if (TempData["CouponSuccess"] != null)
{
    <div class="toast-notification toast-success position-fixed top-0 end-0 m-3" id="couponToast">
        <i class="bi bi-check-circle me-1"></i>@TempData["CouponSuccess"]
    </div>
    <script>setTimeout(()=>document.getElementById('couponToast')?.remove(), 4000);</script>
}
