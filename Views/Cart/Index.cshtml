@model Website_Selling_Phones.Models.ShoppingCart
@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "_ShopLayout";
}

<section class="bg-light py-4 mb-4">
    <div class="container">
        <h2 class="fw-bold mb-1"><i class="bi bi-cart3 me-2"></i>Shopping Cart</h2>
        <p class="text-muted mb-0">@Model.TotalItems item(s) in your cart</p>
    </div>
</section>

<div class="container pb-5">
    @if (Model.Items.Any())
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-0">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th style="width: 120px;">Qty</th>
                                    <th>Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@item.Phone?.ImageUrl" alt="@item.Phone?.Name" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                                                <div>
                                                    <strong>@item.Phone?.Name</strong>
                                                    <br><small class="text-muted">@item.Phone?.Brand</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>$@item.Phone?.DiscountedPrice.ToString("F2")</td>
                                        <td>
                                            <form method="post" action="/Cart/Update">
                                                <input type="hidden" name="id" value="@item.PhoneId">
                                                <input type="number" name="quantity" value="@item.Quantity" min="1" max="10" class="form-control form-control-sm" style="width: 70px;" onchange="this.form.submit()">
                                            </form>
                                        </td>
                                        <td class="fw-bold">$@((item.Phone?.DiscountedPrice ?? 0) * item.Quantity).ToString("F2")</td>
                                        <td>
                                            <form method="post" action="/Cart/Remove">
                                                <input type="hidden" name="id" value="@item.PhoneId">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <a href="/Product" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                </a>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Order Summary</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal</span>
                            <span>$@Model.TotalPrice.ToString("F2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping</span>
                            <span class="text-success">Free</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Total</strong>
                            <strong class="text-primary fs-5">$@Model.TotalPrice.ToString("F2")</strong>
                        </div>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="/Order/Checkout" class="btn btn-primary w-100 btn-lg">Proceed to Checkout</a>
                        }
                        else
                        {
                            <a href="/Account/Login?returnUrl=/Order/Checkout" class="btn btn-primary w-100 btn-lg">Sign In to Checkout</a>
                            <small class="text-muted d-block text-center mt-2">You need an account to checkout</small>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-cart-x"></i>
            <h4>Your cart is empty</h4>
            <p>Looks like you haven't added anything yet.</p>
            <a href="/Product" class="btn btn-primary mt-2">Start Shopping</a>
        </div>
    }
</div>