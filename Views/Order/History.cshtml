@model List<Website_Selling_Phones.Models.Order>
@{
    ViewData["Title"] = "Order History";
    Layout = "_ShopLayout";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4">Order History</h2>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle order-history-table">
                <thead class="table-light">
                    <tr>
                        <th>Order #</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><strong>#@order.Id.ToString("D6")</strong></td>
                            <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td>@order.OrderItems.Count items</td>
                            <td class="fw-bold">$@order.TotalAmount.ToString("F2")</td>
                            <td>
                                <span class="status-badge @(order.Status switch { OrderStatus.Confirmed => "status-badge-confirmed", OrderStatus.Shipped => "status-badge-shipped", OrderStatus.Delivered => "status-badge-delivered", _ => "status-badge-cancelled" })">
                                    @order.Status
                                </span>
                            </td>
                            <td><a href="/Order/Confirmation/@order.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x display-1 text-muted"></i>
            <h3 class="mt-3">No orders yet</h3>
            <p class="text-muted">Start shopping to see your orders here.</p>
            <a href="/Product" class="btn btn-primary">Browse Phones</a>
        </div>
    }
</div>