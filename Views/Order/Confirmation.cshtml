@model Website_Selling_Phones.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
    Layout = "_ItemLayout";
}

<div class="text-center py-5">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success display-1"></i>
    </div>
    <h2 class="fw-bold">Order Confirmed!</h2>
    <p class="text-muted mb-4">Thank you for your purchase. Your order #@Model.Id has been placed.</p>

    <div class="card border-0 shadow-sm text-start mx-auto mb-4" style="max-width: 500px;">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Order Details</h5>
            <div class="small mb-2"><strong>Order #:</strong> @Model.Id</div>
            <div class="small mb-2"><strong>Date:</strong> @Model.OrderDate.ToString("MMM dd, yyyy h:mm tt")</div>
            <div class="small mb-2"><strong>Payment:</strong> @Model.PaymentMethod</div>
            <div class="small mb-2"><strong>Status:</strong> <span class="badge bg-success">@Model.Status</span></div>
            <div class="small mb-2"><strong>Shipping:</strong> @Model.ShippingAddress</div>
            <hr>
            @foreach (var item in Model.OrderItems)
            {
                <div class="d-flex justify-content-between small mb-1">
                    <span>@item.PhoneName x @item.Quantity</span>
                    <span>$@item.Price.ToString("F2")</span>
                </div>
            }
            <hr>
            <div class="d-flex justify-content-between fw-bold">
                <span>Total</span>
                <span class="text-primary">$@Model.TotalAmount.ToString("F2")</span>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-2">
        <a href="/Order/History" class="btn btn-primary">View Orders</a>
        <a href="/Product" class="btn btn-outline-primary">Continue Shopping</a>
    </div>
</div>