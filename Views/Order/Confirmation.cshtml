@model Website_Selling_Phones.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
    Layout = "_ShopLayout";
}

<div class="container py-5 text-center">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size:5rem;"></i>
    </div>
    <h2 class="fw-bold">Thank You for Your Order!</h2>
    <p class="text-muted mb-4">Your order has been placed successfully.</p>

    <div class="border rounded p-4 d-inline-block text-start mx-auto mb-4" style="max-width:500px;">
        <div class="d-flex justify-content-between mb-2"><strong>Order Number:</strong><span>#@Model.Id.ToString("D6")</span></div>
        <div class="d-flex justify-content-between mb-2"><strong>Date:</strong><span>@Model.OrderDate.ToString("MMM dd, yyyy")</span></div>
        <div class="d-flex justify-content-between mb-2"><strong>Total:</strong><span class="fw-bold">$@Model.TotalAmount.ToString("F2")</span></div>
        <div class="d-flex justify-content-between mb-2"><strong>Payment:</strong><span>@Model.PaymentMethod</span></div>
        <div class="d-flex justify-content-between mb-2"><strong>Status:</strong><span class="badge bg-success">@Model.Status</span></div>
    </div>

    <div class="border rounded p-4 mx-auto mb-4" style="max-width:500px;">
        <h6 class="fw-bold mb-3">Order Items</h6>
        @foreach (var item in Model.OrderItems)
        {
            <div class="d-flex justify-content-between small mb-2">
                <span>@item.PhoneName x @item.Quantity</span>
                <span>$@(item.Price * item.Quantity).ToString("F2")</span>
            </div>
        }
    </div>

    <p class="text-muted small">A confirmation email will be sent to @Model.CustomerEmail.</p>
    <div class="d-flex gap-2 justify-content-center">
        <a href="/Order/History" class="btn btn-outline-primary">View Order History</a>
        <a href="/Product" class="btn btn-primary">Continue Shopping</a>
    </div>
</div>