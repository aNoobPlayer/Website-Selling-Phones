@model Website_Selling_Phones.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_ItemLayout";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="auth-card">
            <div class="card-body p-4">
                <h3 class="fw-bold mb-1 text-center">Welcome Back</h3>
                <p class="text-muted text-center mb-4">Sign in to your account</p>

                <form method="post" asp-route-returnUrl="@returnUrl">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" placeholder="you@example.com" required>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" class="form-control" placeholder="••••••" required>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input">
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-auth-submit">Sign In</button>

                    <p class="text-center mb-0 small">
                        Don't have an account? <a href="/Account/Register">Register</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}