@model Website_Selling_Phones.Models.Phone
@{
    ViewData["Title"] = Model.Name;
    Layout = "_ShopLayout";
    var calculatedPrice = ViewData["CalculatedPrice"] as decimal?;
    var promoMessage = ViewData["PromoMessage"] as string;
    var reviews = ViewData["Reviews"] as List<Website_Selling_Phones.Models.Review> ?? new();
    var relatedPhones = ViewData["RelatedPhones"] as List<Website_Selling_Phones.Models.Phone> ?? new();
    var avgRating = Model.Rating > 0 ? Model.Rating : (reviews.Any() ? Math.Round(reviews.Average(r => r.Rating), 1) : 0);
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/Product">Phones</a></li>
        @if (!string.IsNullOrEmpty(Model.Brand))
        {<li class="breadcrumb-item"><a href="/Product?brand=@Model.Brand">@Model.Brand</a></li>}
        <li class="breadcrumb-item active text-truncate" style="max-width:200px;">@Model.Name</li>
    </ol>
</nav>

<div class="row g-4">
    <!-- Image Gallery -->
    <div class="col-lg-6">
        <div class="product-gallery">
            <div class="gallery-main mb-3 position-relative">
                <img id="mainImage" src="@Model.ImageUrl" class="img-fluid w-100 rounded-3 gallery-fade-img" alt="@Model.Name" style="min-height:400px; object-fit:cover;">
                <span class="condition-badge position-absolute top-0 start-0 m-3 @Model.ConditionBadgeClass">@Model.ConditionDisplayName</span>
                @if (Model.DiscountPercentage > 0)
                {<span class="discount-badge discount-badge-detail position-absolute top-0 end-0 m-3">-@Model.DiscountPercentage%</span>}
            </div>
            @if (Model.GalleryImages.Any())
            {
                <div class="gallery-thumbnails d-flex gap-2 overflow-auto pb-1">
                    @foreach (var img in Model.GalleryImages)
                    {
                        <img src="@img" class="gallery-thumb rounded-2 border @(img == Model.GalleryImages.First() ? "active" : "")"
                             alt="Thumbnail" onclick="switchGalleryImage(this, '@img')">
                    }
                </div>
            }
        </div>

        @if (Model.Specs != null)
        {
            <div class="mt-4">
                <h4 class="fw-bold mb-3">Specifications</h4>
                <table class="table table-bordered specs-table">
                    <tr><td class="fw-semibold bg-body-tertiary" style="width:130px;">Display</td><td>@Model.Specs.Display</td></tr>
                    <tr><td class="fw-semibold bg-body-tertiary">Processor</td><td>@Model.Specs.Processor</td></tr>
                    <tr><td class="fw-semibold bg-body-tertiary">RAM</td><td>@Model.Specs.Ram</td></tr>
                    <tr><td class="fw-semibold bg-body-tertiary">Storage</td><td id="specStorage">@Model.Specs.Storage</td></tr>
                    <tr><td class="fw-semibold bg-body-tertiary">Camera</td><td>@Model.Specs.Camera</td></tr>
                    <tr><td class="fw-semibold bg-body-tertiary">Battery</td><td>@Model.Specs.Battery</td></tr>
                    <tr><td class="fw-semibold bg-body-tertiary">OS</td><td>@Model.Specs.Os</td></tr>
                    <tr><td class="fw-semibold bg-body-tertiary">Weight</td><td>@Model.Specs.Weight</td></tr>
                    <tr><td class="fw-semibold bg-body-tertiary">Connectivity</td><td>@Model.Specs.Connectivity</td></tr>
                </table>
            </div>
        }

        <div class="mt-4">
            <h4 class="fw-bold mb-3">
                <i class="bi bi-star-fill text-warning me-1"></i>
                @(avgRating > 0 ? $"{avgRating:F1} / 5" : "No Reviews Yet")
                <small class="text-muted fs-6">(@Model.ReviewCount reviews)</small>
            </h4>

            @foreach (var review in reviews.Take(5))
            {
                <div class="review-card border rounded p-3 mb-2">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <div>
                            <strong>@review.UserName</strong>
                            <span class="badge bg-success ms-2 small">Verified Purchase</span>
                        </div>
                        <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>
                    <div class="mb-1">
                        @for (int i = 1; i <= 5; i++)
                        {<i class="bi @(i <= review.Rating ? "bi-star-fill text-warning" : "bi-star text-muted") small"></i>}
                    </div>
                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                    {<p class="mb-0 small">@review.Comment</p>}
                </div>
            }
        </div>
    </div>

    <!-- Product Info Column -->
    <div class="col-lg-6">
        <header class="mb-3">
            <span class="brand-label text-primary mb-1 d-block">@Model.Brand</span>
            <h1 class="fw-bold mb-2">@Model.Name</h1>
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="text-warning">
                    @for (int i = 1; i <= 5; i++)
                    {<i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star")"></i>}
                </span>
                <span class="text-muted small">(@Model.ReviewCount reviews) | @Model.TotalSold sold</span>
            </div>
            <p class="text-muted">@(Model.FullDescription ?? Model.Description)</p>
        </header>

        <div class="pricing-block mb-4 p-3 rounded-3 border">
            @if (Model.DiscountPercentage > 0)
            {
                <div class="d-flex align-items-baseline gap-3 flex-wrap">
                    <span class="original-price-large text-decoration-line-through text-muted fs-5">$@Model.Price.ToString("F2")</span>
                    <span class="price-tag fs-2 fw-bold text-primary">$@Model.DiscountedPrice.ToString("F2")</span>
                    <span class="badge bg-danger fs-6">Save @Model.DiscountPercentage%</span>
                </div>
            }
            else
            {<span class="price-tag fs-2 fw-bold text-primary">$@Model.Price.ToString("F2")</span>}
            @if (calculatedPrice.HasValue && calculatedPrice.Value != Model.DiscountedPrice)
            {<div class="mt-1"><small class="text-success"><i class="bi bi-stars me-1"></i>VIP Price: $@calculatedPrice.Value.ToString("F2")</small></div>}
        </div>

        @if (!string.IsNullOrEmpty(promoMessage))
        {<div class="promo-banner mb-4"><i class="bi bi-megaphone me-2"></i>@promoMessage</div>}

        @{
            var colors = Model.Variants.Where(v => v.Type == "Color").ToList();
            var storages = Model.Variants.Where(v => v.Type == "Storage").ToList();
        }
        @if (colors.Any())
        {
            <div class="mb-3">
                <label class="form-label fw-semibold">Color</label>
                <div class="d-flex gap-2 flex-wrap" id="colorVariantGroup">
                    @foreach (var c in colors)
                    {<button class="btn btn-outline-dark btn-sm variant-btn" data-type="Color" data-value="@c.Value">@c.Value</button>}
                </div>
            </div>
        }
        @if (storages.Any())
        {
            <div class="mb-3">
                <label class="form-label fw-semibold">Storage</label>
                <div class="d-flex gap-2 flex-wrap" id="storageVariantGroup">
                    @foreach (var s in storages)
                    {
                        <button class="btn btn-outline-dark btn-sm variant-btn @(storages.IndexOf(s) == 0 ? "active" : "")" data-type="Storage" data-value="@s.Value">
                            @s.Value @(s.PriceModifier > 0 ? $"(+${s.PriceModifier})" : "")
                        </button>
                    }
                </div>
            </div>
        }

        <div class="mb-3">
            <span class="fw-bold @Model.StockCssClass">
                @if (Model.StockQuantity > 5)
                {<i class="bi bi-check-circle-fill me-1"></i><span>In Stock</span><small class="text-muted ms-2">(@Model.StockQuantity available)</small>}
                else if (Model.StockQuantity > 0)
                {<i class="bi bi-exclamation-circle-fill me-1"></i><span>Low Stock</span><small class="text-muted ms-2">(Only @Model.StockQuantity left!)</small>}
                else
                {<i class="bi bi-x-circle-fill me-1"></i><span>Out of Stock</span>}
            </span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Quantity</label>
            <div class="input-group" style="max-width:140px;">
                <button class="btn btn-outline-secondary" type="button" onclick="changeQty(-1)">-</button>
                <input type="number" id="qtyInput" class="form-control text-center" value="1" min="1" max="@Model.StockQuantity" readonly>
                <button class="btn btn-outline-secondary" type="button" onclick="changeQty(1)">+</button>
            </div>
        </div>

        <div class="d-flex gap-2 mb-4 flex-wrap">
            @if (Model.StockQuantity > 0)
            {
                <button id="addToCartBtn" class="btn btn-primary btn-lg flex-grow-1 btn-add-to-cart">
                    <i class="bi bi-cart-plus me-2"></i>Add to Cart
                </button>
                <button id="buyNowBtn" class="btn btn-outline-primary btn-lg px-4">Buy Now</button>
            }
            else
            {<button class="btn btn-secondary btn-lg flex-grow-1" disabled><i class="bi bi-x-circle me-2"></i>Out of Stock</button>}
            <button class="btn btn-outline-secondary btn-lg px-3 wishlist-btn" data-id="@Model.Id">
                <i class="bi bi-heart"></i>
            </button>
            <button id="shareBtn" class="btn btn-outline-secondary btn-lg px-3">
                <i class="bi bi-share"></i>
            </button>
        </div>

        <div class="trust-strip p-3 rounded-3 border mb-4">
            <h6 class="fw-bold mb-2 small text-uppercase text-muted">Why buy from us</h6>
            <div class="row g-2 small">
                <div class="col-6"><i class="bi bi-truck me-1 text-primary"></i>Free Shipping over $500</div>
                <div class="col-6"><i class="bi bi-shield-check me-1 text-primary"></i>2-Year Warranty</div>
                <div class="col-6"><i class="bi bi-arrow-return-left me-1 text-primary"></i>30-Day Returns</div>
                <div class="col-6"><i class="bi bi-lock-fill me-1 text-primary"></i>Secure Checkout</div>
            </div>
        </div>

        <div class="mt-3">
            <h6 class="fw-bold mb-2">Write a Review</h6>
            @if (TempData["ReviewSuccess"] != null)
            {<div class="alert alert-success py-2 mb-3">@TempData["ReviewSuccess"]</div>}
            @if (TempData["ReviewError"] != null)
            {<div class="alert alert-danger py-2 mb-3">@TempData["ReviewError"]</div>}
            <div id="reviewError" class="alert alert-danger py-2 mb-3 d-none"></div>
            <form method="post" action="/Product/SubmitReview" onsubmit="return validateReview(this)">
                @Html.AntiForgeryToken()
                <input type="hidden" name="phoneId" value="@Model.Id">
                <div class="mb-2">
                    <div class="star-rating">
                        @for (int i = 5; i >= 1; i--)
                        {
                            <input type="radio" id="star@i" name="rating" value="@i" @(i == 5 ? "checked" : "")>
                            <label for="star@i"><i class="bi bi-star-fill"></i></label>
                        }
                    </div>
                </div>
                <textarea name="comment" class="form-control mb-2" rows="2" placeholder="Share your thoughts (min 10 characters)..." required minlength="10" maxlength="500"></textarea>
                <button type="submit" class="btn btn-outline-primary btn-sm">Submit Review</button>
            </form>
        </div>
    </div>
</div>

@if (relatedPhones.Any())
{
    <section class="mt-5">
        <h3 class="fw-bold mb-3">You May Also Like</h3>
        <div class="row g-3">
            @foreach (var related in relatedPhones)
            {
                <div class="col-6 col-md-3">
                    <a href="/Product/Details/@related.Id" class="text-decoration-none text-reset">
                        <div class="card related-card h-100">
                            <img src="@related.ImageUrl" class="card-img-top" alt="@related.Name" style="height:180px; object-fit:cover;">
                            <div class="card-body p-2">
                                <small class="brand-label d-block">@related.Brand</small>
                                <p class="card-text small fw-semibold mb-1">@related.Name</p>
                                <span class="text-primary fw-bold small">$@related.DiscountedPrice.ToString("F0")</span>
                                <div class="small text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {<i class="bi @(i <= Math.Round(related.Rating) ? "bi-star-fill" : "bi-star") small"></i>}
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </section>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script type="module">
        import { initVariantSwitcher } from '/js/modules/variant-switcher.js';
        initVariantSwitcher(@Model.Id);
    </script>
    <script>
        function changeQty(delta) {
            var input = document.getElementById('qtyInput');
            var val = parseInt(input.value) + delta;
            if (val < 1) val = 1;
            if (val > @Model.StockQuantity) val = @Model.StockQuantity;
            input.value = val;
        }

        function switchGalleryImage(thumb, src) {
            var main = document.getElementById('mainImage');
            main.style.opacity = '0';
            setTimeout(() => { main.src = src; main.style.opacity = '1'; }, 300);
            document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
            thumb.classList.add('active');
        }

        function updateCartBadge(count) {
            document.querySelectorAll('.cart-count-badge').forEach(b => {
                b.textContent = count;
                b.style.display = count > 0 ? '' : 'none';
            });
        }

        function showToast(msg) {
            var toast = document.createElement('div');
            toast.className = 'cart-toast show';
            toast.textContent = msg;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2500);
        }

        // Add to Cart - AJAX
        document.getElementById('addToCartBtn')?.addEventListener('click', async function() {
            var qty = document.getElementById('qtyInput').value;
            var color = document.querySelector('.variant-btn[data-type="Color"].active')?.dataset.value || '';
            var storage = document.querySelector('.variant-btn[data-type="Storage"].active')?.dataset.value || '';
            var params = new URLSearchParams();
            params.append('id', '@Model.Id');
            params.append('quantity', qty);
            if (color) params.append('color', color);
            if (storage) params.append('storage', storage);

            var resp = await fetch('/Cart/AddAjax', { method: 'POST', body: params });
            var data = await resp.json();

            this.classList.add('cart-success');
            this.innerHTML = '<i class="bi bi-check-lg fs-5"></i>';
            setTimeout(() => {
                this.classList.remove('cart-success');
                this.innerHTML = '<i class="bi bi-cart-plus me-2"></i>Add to Cart';
            }, 1200);

            showToast(data.itemName + ' added to cart!');
            updateCartBadge(data.totalItems);
        });

        // Buy Now - add to cart then redirect
        document.getElementById('buyNowBtn')?.addEventListener('click', async function() {
            var qty = document.getElementById('qtyInput').value;
            var color = document.querySelector('.variant-btn[data-type="Color"].active')?.dataset.value || '';
            var storage = document.querySelector('.variant-btn[data-type="Storage"].active')?.dataset.value || '';
            var params = new URLSearchParams();
            params.append('id', '@Model.Id');
            params.append('quantity', qty);
            if (color) params.append('color', color);
            if (storage) params.append('storage', storage);

            await fetch('/Cart/AddAndCheckout', { method: 'POST', body: params });
            window.location.href = '/Order/Checkout';
        });

        // SignalR
        const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/inventory").build();
        connection.on("ReceivePriceUpdate", data => {
            if (data.productName === "@Model.Name") {
                const tag = document.querySelector('.price-tag');
                if (tag) {
                    const target = data.newPrice;
                    const current = parseFloat(tag.textContent.replace(/[^0-9.]/g, ''));
                    if (!isNaN(current)) {
                        const start = performance.now();
                        function update(now) {
                            const progress = Math.min((now - start) / 400, 1);
                            const eased = 1 - Math.pow(1 - progress, 3);
                            tag.textContent = '$' + (current + (target - current) * eased).toFixed(2);
                            if (progress < 1) requestAnimationFrame(update);
                        }
                        requestAnimationFrame(update);
                    }
                }
            }
        });
        connection.start().catch(err => console.log("SignalR:", err));

        // Wishlist
        fetch('/Wishlist/IsInWishlist?id=@Model.Id')
            .then(r => r.json())
            .then(data => {
                var icon = document.querySelector('.wishlist-btn i');
                if (data.inWishlist) { icon.classList.remove('bi-heart'); icon.classList.add('bi-heart-fill', 'text-danger'); }
            });

        document.querySelector('.wishlist-btn')?.addEventListener('click', function() {
            var btn = this;
            fetch('/Wishlist/Toggle', { method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'}, body: 'id=@Model.Id' })
                .then(r => r.json())
                .then(data => {
                    var icon = btn.querySelector('i');
                    if (data.added) { icon.classList.remove('bi-heart'); icon.classList.add('bi-heart-fill', 'text-danger'); }
                    else { icon.classList.remove('bi-heart-fill', 'text-danger'); icon.classList.add('bi-heart'); }
                });
        });

        // Share - clipboard fallback
        document.getElementById('shareBtn')?.addEventListener('click', function() {
            var url = window.location.href;
            if (navigator.share) {
                navigator.share({ title: '@Model.Name', url: url });
            } else {
                navigator.clipboard.writeText(url).then(() => {
                    var btn = this;
                    var orig = btn.innerHTML;
                    btn.innerHTML = '<i class="bi bi-clipboard-check text-success"></i>';
                    setTimeout(() => { btn.innerHTML = orig; }, 1500);
                });
            }
        });

        // Review validation
        function validateReview(form) {
            var comment = form.querySelector('textarea[name="comment"]').value.trim();
            var rating = form.querySelector('input[name="rating"]:checked')?.value;
            var error = document.getElementById('reviewError');
            if (!rating || parseInt(rating) < 1) {
                error.textContent = 'Please select a star rating.';
                error.classList.remove('d-none');
                return false;
            }
            if (comment.length < 10) {
                error.textContent = 'Please write at least 10 characters for your review.';
                error.classList.remove('d-none');
                return false;
            }
            error.classList.add('d-none');
            return true;
        }
    </script>
}