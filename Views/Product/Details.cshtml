@model Website_Selling_Phones.Models.Phone
@{
    ViewData["Title"] = Model.Name;
    Layout = "_ItemLayout";
    var calculatedPrice = ViewData["CalculatedPrice"] as decimal?;
    var promoMessage = ViewData["PromoMessage"] as string;
}

<div class="row g-5">
    <!-- Product Gallery -->
    <div class="col-lg-6">
        <figure class="product-gallery">
            <img src="@Model.ImageUrl" class="img-fluid w-100" alt="@Model.Name" style="min-height: 450px; object-fit: cover;">
            <figcaption class="gallery-badge @Model.ConditionBadgeClass">
                @Model.ConditionDisplayName
            </figcaption>
        </figure>
    </div>

    <!-- Product Details -->
    <div class="col-lg-6">
        <header class="mb-4">
            <span class="brand-label mb-2 d-block">@Model.Brand</span>
            <h1 class="fw-bold mb-2">@Model.Name</h1>
            <p class="text-muted">@Model.Description</p>
        </header>

        <!-- Dynamic Pricing -->
        <div class="pricing-block mb-4">
            @if (Model.DiscountPercentage > 0)
            {
                <div class="d-flex align-items-baseline gap-3">
                    <span class="original-price-large text-decoration-line-through text-muted">$@Model.Price.ToString("F2")</span>
                    <span class="price-tag">$@Model.DiscountedPrice.ToString("F2")</span>
                    <span class="badge bg-danger ms-2">Save @Model.DiscountPercentage%</span>
                </div>
            }
            else
            {
                <span class="price-tag">$@Model.Price.ToString("F2")</span>
            }
            @if (calculatedPrice.HasValue && calculatedPrice.Value != Model.DiscountedPrice)
            {
                <div class="mt-1">
                    <small class="text-success">
                        <i class="bi bi-stars me-1"></i>VIP Price: $@calculatedPrice.Value.ToString("F2")
                    </small>
                </div>
            }
        </div>

        <!-- Promo Message -->
        @if (!string.IsNullOrEmpty(promoMessage))
        {
            <div class="promo-banner mb-4">
                <i class="bi bi-megaphone me-2"></i>@promoMessage
            </div>
        }

        <!-- Specs -->
        <dl class="row mb-4">
            <dt class="col-sm-4 text-muted">Model</dt>
            <dd class="col-sm-8 fw-semibold">@Model.Model</dd>

            <dt class="col-sm-4 text-muted">Condition</dt>
            <dd class="col-sm-8">
                <span class="badge @(Model.Condition == PhoneCondition.New ? "bg-success" : Model.ConditionDisplayName == "Refurbished" ? "bg-info" : "bg-secondary")">
                    @Model.ConditionDisplayName
                </span>
            </dd>

            <dt class="col-sm-4 text-muted">Category</dt>
            <dd class="col-sm-8">@Model.Category</dd>

            <dt class="col-sm-4 text-muted">Availability</dt>
            <dd class="col-sm-8">
                @if (Model.StockQuantity > 5)
                {
                    <span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i>In Stock</span>
                    <small class="text-muted ms-2">(@Model.StockQuantity available)</small>
                }
                else if (Model.StockQuantity > 0)
                {
                    <span class="text-warning fw-bold stock-urgent-pulse"><i class="bi bi-exclamation-circle-fill me-1"></i>Low Stock</span>
                    <small class="text-muted ms-2">(Only @Model.StockQuantity left!)</small>
                }
                else
                {
                    <span class="text-danger fw-bold"><i class="bi bi-x-circle-fill me-1"></i>Out of Stock</span>
                }
            </dd>
        </dl>

        <!-- Add to Cart with Micro-animation -->
        <div class="d-flex gap-3">
            @if (Model.StockQuantity > 0)
            {
                <button class="btn btn-primary btn-lg flex-grow-1 btn-add-to-cart" onclick="addToCart(this, '@Model.Name')">
                    <i class="bi bi-cart-plus me-2"></i>Add to Cart
                </button>
                <button class="btn btn-outline-primary btn-lg px-3" title="Add to wishlist">
                    <i class="bi bi-heart"></i>
                </button>
            }
            else
            {
                <button class="btn btn-secondary btn-lg flex-grow-1" disabled>
                    <i class="bi bi-x-circle me-2"></i>Out of Stock
                </button>
            }
        </div>

        <!-- Guarantee Strip -->
        <div class="guarantee-strip mt-4">
            <div class="row text-center g-0">
                <div class="col-4"><i class="bi bi-truck me-1"></i>Free Shipping</div>
                <div class="col-4"><i class="bi bi-shield-check me-1"></i>2-Year Warranty</div>
                <div class="col-4"><i class="bi bi-arrow-return-left me-1"></i>30-Day Returns</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(btn, productName) {
            // Success bounce animation
            btn.classList.add('cart-success');
            btn.innerHTML = '<i class="bi bi-check-lg me-2"></i>Added!';

            setTimeout(() => {
                btn.classList.remove('cart-success');
                btn.innerHTML = '<i class="bi bi-cart-plus me-2"></i>Add to Cart';
            }, 1500);

            // Show toast
            const toast = document.createElement('div');
            toast.className = 'cart-toast';
            toast.innerHTML = `<i class="bi bi-check-circle-fill me-2"></i>${productName} added to cart!`;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 2000);
            }, 100);
        }
    </script>
}