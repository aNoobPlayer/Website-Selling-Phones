@model List<Website_Selling_Phones.Models.Phone>
@{
    ViewData["Title"] = "Shop";
    Layout = "_ShopLayout";
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalItems = (int)(ViewData["TotalItems"] ?? 0);
    var search = ViewData["Search"] as string ?? "";
    var currentBrand = ViewData["CurrentBrand"] as string ?? "";
    var currentCategory = ViewData["CurrentCategory"] as string ?? "";
    var currentCondition = ViewData["CurrentCondition"] as string ?? "";
    var currentSort = ViewData["CurrentSort"] as string ?? "featured";
    var viewMode = ViewData["ViewMode"] as string ?? "grid";
    var minPrice = ViewData["MinPrice"] as decimal? ?? 0;
    var maxPrice = ViewData["MaxPrice"] as decimal? ?? 1500;
    var activeFilterCount = (int)(ViewData["ActiveFilterCount"] ?? 0);
    var brands = ViewData["Brands"] as List<string> ?? new();
    var categories = ViewData["Categories"] as List<string> ?? new();
}

<nav aria-label="breadcrumb" class="container pt-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item active">Shop</li>
        @if (!string.IsNullOrEmpty(currentBrand))
        {<li class="breadcrumb-item active">@currentBrand</li>}
    </ol>
</nav>

<header class="page-header">
    <div class="container">
        <h2 class="fw-bold mb-1">Shop</h2>
        <p class="opacity-75 mb-0" id="resultCount">@totalItems results</p>
    </div>
</header>

<div class="container py-4">
    <div class="row">
        <!-- Sidebar Filters -->
        <aside class="col-lg-3 mb-4">
            <div class="sidebar-filter">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Filters</h5>
                    <span class="badge bg-primary rounded-pill" id="activeFilterCount" style="@(activeFilterCount == 0 ? "display:none" : "")">@activeFilterCount active</span>
                </div>

                <!-- Search -->
                <div class="sidebar-section p-3 mb-3 border rounded">
                    <div class="position-relative">
                        <input type="text" id="searchInput" class="form-control" value="@search" placeholder="Search phones..." autocomplete="off">
                        <div id="searchSuggestions" class="search-suggestions d-none position-absolute w-100 bg-white border rounded shadow-sm"></div>
                    </div>
                </div>

                <!-- Price Range Slider -->
                <div class="sidebar-section p-3 mb-3 border rounded">
                    <h6 class="fw-bold small text-uppercase text-muted mb-3">Price Range</h6>
                    <div id="priceSlider" class="mb-3" style="margin: 0 8px;"></div>
                    <div class="d-flex justify-content-between small text-muted">
                        <span id="minPriceLabel">$@minPrice.ToString("F0")</span>
                        <span id="maxPriceLabel">$@maxPrice.ToString("F0")</span>
                    </div>
                </div>

                <!-- Brand -->
                <div class="sidebar-section p-3 mb-3 border rounded">
                    <h6 class="fw-bold small text-uppercase text-muted mb-2">Brand</h6>
                    @foreach (var brand in brands)
                    {
                        <a href="?brand=@brand&category=@currentCategory&condition=@currentCondition&sort=@currentSort&search=@search" class="d-block filter-link @(currentBrand == brand ? "active" : "")">@brand</a>
                    }
                    @if (!string.IsNullOrEmpty(currentBrand))
                    {<a href="?category=@currentCategory&sort=@currentSort&search=@search" class="d-block text-danger small filter-link">Clear brand filter</a>}
                </div>

                <!-- Category -->
                <div class="sidebar-section p-3 mb-3 border rounded">
                    <h6 class="fw-bold small text-uppercase text-muted mb-2">Category</h6>
                    @foreach (var cat in categories)
                    {
                        <a href="?brand=@currentBrand&category=@cat&condition=@currentCondition&sort=@currentSort&search=@search" class="d-block filter-link @(currentCategory == cat ? "active" : "")">@cat</a>
                    }
                </div>

                <!-- Condition -->
                <div class="sidebar-section p-3 mb-3 border rounded">
                    <h6 class="fw-bold small text-uppercase text-muted mb-2">Condition</h6>
                    <div class="d-flex flex-wrap gap-1">
                        <a href="?brand=@currentBrand&category=@currentCategory&condition=New&sort=@currentSort&search=@search" class="btn btn-sm @(currentCondition == "New" ? "btn-primary" : "btn-outline-secondary")">New</a>
                        <a href="?brand=@currentBrand&category=@currentCategory&condition=Refurbished&sort=@currentSort&search=@search" class="btn btn-sm @(currentCondition == "Refurbished" ? "btn-primary" : "btn-outline-secondary")">Refurbished</a>
                        <a href="?brand=@currentBrand&category=@currentCategory&condition=Used&sort=@currentSort&search=@search" class="btn btn-sm @(currentCondition == "Used" ? "btn-primary" : "btn-outline-secondary")">Used</a>
                    </div>
                </div>

                @if (activeFilterCount > 0)
                {<a href="/Product" class="btn btn-outline-danger btn-sm w-100 mt-2 filter-link">Clear All Filters</a>}
            </div>
        </aside>

        <!-- Main Content -->
        <main class="col-lg-9">
            <!-- Toolbar -->
            <div class="toolbar d-flex flex-wrap justify-content-between align-items-center mb-3 p-3 border rounded">
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small" id="resultCount2">@totalItems results</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <select id="sortSelect" class="form-select form-select-sm w-auto">
                        <option value="featured" selected=@(currentSort == "featured")>Featured</option>
                        <option value="price_asc" selected=@(currentSort == "price_asc")>Price: Low-High</option>
                        <option value="price_desc" selected=@(currentSort == "price_desc")>Price: High-Low</option>
                        <option value="newest" selected=@(currentSort == "newest")>Newest</option>
                        <option value="rating" selected=@(currentSort == "rating")>Highest Rated</option>
                        <option value="popularity" selected=@(currentSort == "popularity")>Most Popular</option>
                    </select>
                    <div class="btn-group btn-group-sm">
                        <button class="btn view-toggle-btn @(viewMode != "list" ? "btn-primary" : "btn-outline-secondary")" data-view="grid"><i class="bi bi-grid-fill"></i></button>
                        <button class="btn view-toggle-btn @(viewMode == "list" ? "btn-primary" : "btn-outline-secondary")" data-view="list"><i class="bi bi-list"></i></button>
                    </div>
                </div>
            </div>

            <!-- Products Grid -->
            <div id="productGrid" class="@(viewMode == "list" ? "product-list-view" : "product-grid")">
                <partial name="_ProductGrid" model="@(Model, viewMode)" />
            </div>

            <!-- Pagination -->
            <div id="paginationBar">
                <partial name="_Pagination" />
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state text-center py-5" id="emptyState">
                    <i class="bi bi-search display-1 text-muted"></i>
                    <h4>No phones found</h4>
                    <p class="text-muted">Try adjusting your search or filters.</p>
                    <a href="/Product" class="btn btn-primary filter-link">View All Phones</a>
                </div>
            }
        </main>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/nouislider@15.7.0/dist/nouislider.min.css">
    <script src="https://cdn.jsdelivr.net/npm/nouislider@15.7.0/dist/nouislider.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script type="module">
        import { initLiquidFilters } from '/js/modules/liquid-filters.js';
        initLiquidFilters();
    </script>
    <script>
        // SignalR
        const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/inventory").build();
        connection.on("ReceiveLowStockAlert", data => {
            const toast = document.createElement('div');
            toast.className = 'toast-notification toast-warning';
            toast.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>' + data.message;
            document.querySelector('main')?.prepend(toast);
            setTimeout(() => toast.remove(), 5000);
        });
        connection.start().catch(err => console.log("SignalR:", err));

        // noUiSlider
        var priceSlider = document.getElementById('priceSlider');
        if (priceSlider) {
            noUiSlider.create(priceSlider, {
                start: [@minPrice, @maxPrice],
                connect: true,
                range: { min: 0, max: 1500 },
                step: 50,
                tooltips: [true, true],
                format: { to: v => '$' + Math.round(v), from: v => Number(v.replace('$','')) }
            });
            var priceTimeout;
            priceSlider.noUiSlider.on('change', function(values) {
                clearTimeout(priceTimeout);
                priceTimeout = setTimeout(() => {
                    const params = new URLSearchParams(window.location.search);
                    if (values[0] !== '$0') params.set('minPrice', values[0].replace('$',''));
                    else params.delete('minPrice');
                    if (values[1] !== '$1500') params.set('maxPrice', values[1].replace('$',''));
                    else params.delete('maxPrice');
                    params.set('page', '1');
                    if (typeof fetchFilterResults === 'function') {
                        fetchFilterResults(params);
                    } else {
                        window.location.href = window.location.pathname + '?' + params.toString();
                    }
                }, 400);
            });
            document.getElementById('minPriceLabel').textContent = '$@minPrice.ToString("F0")';
            document.getElementById('maxPriceLabel').textContent = '$@maxPrice.ToString("F0")';
        }

        // AJAX search suggestions
        var searchTimeout;
        document.getElementById('searchInput')?.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            var q = this.value;
            var suggestionsDiv = document.getElementById('searchSuggestions');
            if (q.length < 2) { suggestionsDiv.classList.add('d-none'); return; }
            searchTimeout = setTimeout(() => {
                fetch('/Product/SearchSuggestions?q=' + encodeURIComponent(q))
                    .then(r => r.json())
                    .then(data => {
                        if (!data.length) { suggestionsDiv.classList.add('d-none'); return; }
                        suggestionsDiv.innerHTML = data.map(p =>
                            '<a href="/Product/Details/' + p.id + '" class="search-suggestion-item d-flex align-items-center gap-2 p-2 text-decoration-none text-reset border-bottom">' +
                            '<img src="' + p.image + '" width="40" height="40" class="rounded" style="object-fit:cover">' +
                            '<div><strong>' + p.name + '</strong><br><small class="text-muted">' + p.brand + ' - $' + p.price.toFixed(0) + '</small></div>' +
                            '</a>'
                        ).join('');
                        suggestionsDiv.classList.remove('d-none');
                    });
            }, 300);
        });
        document.addEventListener('click', e => {
            if (!e.target.closest('#searchInput') && !e.target.closest('#searchSuggestions'))
                document.getElementById('searchSuggestions')?.classList.add('d-none');
        });

        // AJAX cart (initial load)
        document.querySelectorAll('#productGrid .ajax-cart-form').forEach(form => {
            form.addEventListener('submit', async e => {
                e.preventDefault();
                var formData = new FormData(form);
                var response = await fetch('/Cart/AddAjax', { method: 'POST', body: formData });
                var data = await response.json();
                var btn = form.querySelector('button');
                if (btn) {
                    btn.classList.add('cart-success');
                    btn.innerHTML = '<i class="bi bi-check-lg"></i>';
                    setTimeout(() => { btn.classList.remove('cart-success'); btn.innerHTML = 'Add to Cart'; }, 1000);
                }
                updateCartCount(data.totalItems);
            });
        });

        function updateCartCount(count) {
            document.querySelectorAll('.cart-count-badge').forEach(b => {
                b.textContent = count;
                b.style.display = count > 0 ? '' : 'none';
            });
        }

        // Wishlist quick toggle (initial load)
        document.querySelectorAll('.wishlist-quick-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                var id = this.dataset.id;
                fetch('/Wishlist/Toggle', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:'id='+id })
                    .then(r => r.json())
                    .then(data => {
                        this.querySelector('i').classList.toggle('bi-heart-fill', data.added);
                        this.querySelector('i').classList.toggle('text-danger', data.added);
                        this.querySelector('i').classList.toggle('bi-heart', !data.added);
                    });
            });
        });
    </script>
}