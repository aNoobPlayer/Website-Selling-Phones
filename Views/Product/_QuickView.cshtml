@model Website_Selling_Phones.Models.Phone
<div class="quick-view-modal" onclick="this.remove()">
    <div class="quick-view-content" onclick="event.stopPropagation()">
        <button class="btn-close position-absolute top-0 end-0 m-3" onclick="this.closest('.quick-view-modal').remove()"></button>
        <div class="row g-3 p-3">
            <div class="col-md-6">
                <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name">
            </div>
            <div class="col-md-6">
                <h5 class="fw-bold">@Model.Name</h5>
                <p class="text-muted small">@Model.Brand</p>
                <div class="mb-2">
                    <span class="fw-bold text-primary fs-5">$@Model.DiscountedPrice.ToString("F0")</span>
                    @if (Model.DiscountPercentage > 0)
                    {<span class="badge bg-danger ms-2">-@Model.DiscountPercentage%</span>}
                </div>
                <p class="small">@Model.Description</p>
                <div class="text-warning small mb-2">
                    @for (int i = 1; i <= 5; i++)
                    {<i class="bi @(i <= Math.Round(Model.Rating) ? "bi-star-fill" : "bi-star")"></i>}
                    <span class="text-muted">(@Model.ReviewCount)</span>
                </div>
                <form method="post" action="/Cart/AddAjax">
                    <input type="hidden" name="id" value="@Model.Id">
                    <button type="submit" class="btn btn-primary btn-sm">Add to Cart</button>
                </form>
                <a href="/Product/Details/@Model.Id" class="btn btn-outline-primary btn-sm">Full Details</a>
            </div>
        </div>
    </div>
</div>

<style>
    .quick-view-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.2s ease; }
    .quick-view-content { background: #fff; border-radius: 12px; max-width: 700px; width: 90%; position: relative; animation: scaleIn 0.2s ease; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes scaleIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
</style>