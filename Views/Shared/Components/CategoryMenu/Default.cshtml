@model Website_Selling_Phones.ViewComponents.CategoryMenuViewModel
@{
    var currentCategory = ViewData["CurrentCategory"] as string;
}

<!-- Sidebar Component -->
<div class="sidebar-filter">
    <div class="sidebar-section">
        <h4 class="sidebar-title"><i class="bi bi-funnel me-2"></i>Filters</h4>

        <!-- Category Filter -->
        <div class="filter-group">
            <h5>Category</h5>
            <ul class="filter-list">
                <li>
                    <a href="@Url.Action("Index", "Product", new { category = (string?)null })" class="@(string.IsNullOrEmpty(currentCategory) ? "active" : "")">
                        All Phones
                        <span class="count">@Model.TotalProducts</span>
                    </a>
                </li>
                @foreach (var cat in Model.Categories)
                {
                    <li>
                        <a href="@Url.Action("Index", "Product", new { category = cat })" class="@(currentCategory == cat ? "active" : "")">
                            @cat
                        </a>
                    </li>
                }
            </ul>
        </div>

        <!-- Condition Filter -->
        <div class="filter-group">
            <h5>Condition</h5>
            <ul class="filter-list">
                <li>
                    <a href="@Url.Action("Index", "Product", new { condition = "New" })">
                        <i class="bi bi-phone me-1"></i>New
                        <span class="count">@Model.NewProducts</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Product", new { condition = "Refurbished" })">
                        <i class="bi bi-arrow-repeat me-1"></i>Refurbished
                        <span class="count">@Model.RefurbishedProducts</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Product", new { condition = "Used" })">
                        <i class="bi bi-hand-index me-1"></i>Used
                        <span class="count">@Model.UsedProducts</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Product")" class="text-danger">
                        <i class="bi bi-tag-fill me-1"></i>On Sale
                        <span class="count">@Model.OnSaleCount</span>
                    </a>
                </li>
            </ul>
        </div>

        <!-- Brand Filter -->
        <div class="filter-group">
            <h5>Brand</h5>
            <ul class="filter-list">
                @foreach (var brand in Model.Brands)
                {
                    <li>
                        <a href="@Url.Action("Index", "Product", new { brand = brand })">@brand</a>
                    </li>
                }
            </ul>
        </div>

        <!-- Price Filter -->
        <div class="filter-group">
            <h5>Price Range</h5>
            <form method="get" action="/Product">
                <div class="price-range-inputs">
                    <input type="number" name="minPrice" class="form-control form-control-sm" placeholder="Min $" min="0">
                    <span class="text-muted">—</span>
                    <input type="number" name="maxPrice" class="form-control form-control-sm" placeholder="Max $" min="0">
                </div>
                <button type="submit" class="btn btn-primary btn-sm w-100 mt-2">Apply</button>
            </form>
        </div>
    </div>
</div>