@{
    Layout = "_ShopLayout";
    ViewData["Title"] = "Page Not Found";
}

<div class="container py-5 text-center">
    <div class="mb-4">
        <i class="bi bi-emoji-frown" style="font-size:6rem; color:#ccc;"></i>
    </div>
    <h1 class="display-3 fw-bold text-muted">404</h1>
    <h3 class="fw-bold mb-2">Page Not Found</h3>
    <p class="text-muted mb-4">The page you're looking for doesn't exist or has been moved.</p>
    <div class="d-flex gap-3 justify-content-center">
        <a href="/" class="btn btn-primary"><i class="bi bi-house-fill me-1"></i>Go Home</a>
        <a href="/Product" class="btn btn-outline-primary"><i class="bi bi-phone me-1"></i>Browse Phones</a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Go Back</a>
    </div>
</div>