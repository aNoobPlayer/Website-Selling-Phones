@model List<Website_Selling_Phones.Models.Phone>
@{
    ViewData["Title"] = "Wishlist";
    Layout = "_ShopLayout";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-heart-fill text-danger me-2"></i>My Wishlist</h2>

    @if (Model.Any())
    {
        <div class="product-grid">
            @foreach (var phone in Model)
            {
                <article class="product-card-v2">
                    <figure class="product-image-container">
                        <img src="@phone.ImageUrl" alt="@phone.Name" loading="lazy">
                        <figcaption class="condition-badge @phone.ConditionBadgeClass">@phone.ConditionDisplayName</figcaption>
                    </figure>
                    <div class="product-info">
                        <span class="brand-label">@phone.Brand</span>
                        <h3>@phone.Name</h3>
                        <div class="price-row">
                            <span class="current-price">$@phone.DiscountedPrice.ToString("F0")</span>
                        </div>
                    </div>
                    <footer class="product-actions d-flex gap-1">
                        <a href="/Product/Details/@phone.Id" class="btn btn-outline-primary btn-sm flex-grow-1">Details</a>
                        <button class="btn btn-outline-danger btn-sm remove-wishlist" data-id="@phone.Id"><i class="bi bi-trash"></i></button>
                    </footer>
                </article>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-heartbreak display-1 text-muted"></i>
            <h3 class="mt-3">Your wishlist is empty</h3>
            <p class="text-muted">Save items you love by clicking the heart icon.</p>
            <a href="/Product" class="btn btn-primary">Browse Phones</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.remove-wishlist').forEach(btn => {
            btn.addEventListener('click', function() {
                fetch('/Wishlist/Toggle', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:'id='+this.dataset.id })
                    .then(() => location.reload());
            });
        });
    </script>
}